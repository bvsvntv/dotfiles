[user]
	email = developer.basanta@gmail.com
	name = iambasantarai
[init]
	defaultBranch = main
[merge]
	conflictStyle = diff3
[core]
	excludesfile = /home/basanta/.gitignore_global
[alias]
	logtree = log --graph --decorate --pretty=oneline --abbrev-commit --all
    dwp = "!f() { git branch -D $(git branch | grep \"$1\"); }; f"
[includeIf "gitdir:~/Work/"]
    path = ~/dotfiles/personal/git-config/.gitconfig_eb_pearls
